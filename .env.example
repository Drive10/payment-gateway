# ============================================================
# Payment Gateway - Environment Variables
# Copy this file to .env and replace all REPLACE_* values
# NEVER commit .env to version control
# ============================================================

# ---- Security ----
JWT_SECRET_B64=REPLACE_WITH_BASE64_ENCODED_32BYTE_SECRET
GATEWAY_INTERNAL_SECRET=REPLACE_WITH_STRONG_INTERNAL_SHARED_SECRET
VAULT_ROOT_TOKEN=REPLACE_WITH_STRONG_VAULT_TOKEN

# ---- PostgreSQL ----
POSTGRES_USER=payment
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD

# ---- Redis ----
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_GRAFANA_PASSWORD

# ---- Service Database Credentials ----
AUTH_DB_USER=auth
AUTH_DB_PASSWORD=REPLACE_WITH_STRONG_AUTH_DB_PASSWORD

ORDER_DB_USER=order
ORDER_DB_PASSWORD=REPLACE_WITH_STRONG_ORDER_DB_PASSWORD

PAYMENT_DB_USER=payment
PAYMENT_DB_PASSWORD=REPLACE_WITH_STRONG_PAYMENT_DB_PASSWORD
# Note: full Docker uses POSTGRES_PASSWORD for payment-service because the bootstrap
# postgres superuser is also the payment database owner in dev.

NOTIFICATION_DB_USER=notification
NOTIFICATION_DB_PASSWORD=REPLACE_WITH_STRONG_NOTIFICATION_DB_PASSWORD

WEBHOOK_DB_USER=webhook
WEBHOOK_DB_PASSWORD=REPLACE_WITH_STRONG_WEBHOOK_DB_PASSWORD

SIMULATOR_DB_USER=simulator
SIMULATOR_DB_PASSWORD=REPLACE_WITH_STRONG_SIMULATOR_DB_PASSWORD

SETTLEMENT_DB_USER=settlement
SETTLEMENT_DB_PASSWORD=REPLACE_WITH_STRONG_SETTLEMENT_DB_PASSWORD

RISK_DB_USER=risk
RISK_DB_PASSWORD=REPLACE_WITH_STRONG_RISK_DB_PASSWORD

ANALYTICS_DB_USER=analytics
ANALYTICS_DB_PASSWORD=REPLACE_WITH_STRONG_ANALYTICS_DB_PASSWORD

MERCHANT_DB_USER=merchant
MERCHANT_DB_PASSWORD=REPLACE_WITH_STRONG_MERCHANT_DB_PASSWORD

DISPUTE_DB_USER=dispute
DISPUTE_DB_PASSWORD=REPLACE_WITH_STRONG_DISPUTE_DB_PASSWORD

# ---- Optional ----
CONFIG_GIT_URI=https://github.com/example/payment-gateway-config.git
