# =============================================================================
# PayFlow - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=payflow
POSTGRES_PASSWORD=payflow_secure_password_change_me
POSTGRES_DB=payflow
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PASSWORD=payflow_secure_password_change_me
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Kafka Configuration
# -----------------------------------------------------------------------------
KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=29092
ZOOKEEPER_PORT=2181
KAFKA_TOPIC_PAYMENT_EVENTS=payment.events
KAFKA_TOPIC_PAYMENT_EVENTS_DLT=payment.events.dlt
KAFKA_TOPIC_PAYMENT_STATUS_UPDATED=payment.status.updated
KAFKA_TOPIC_WEBHOOK_UPDATES=webhook.updates

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
ORDER_SERVICE_PORT=8082
PAYMENT_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
ANALYTICS_SERVICE_PORT=8085
SIMULATOR_SERVICE_PORT=8086
AUDIT_SERVICE_PORT=8087
FRONTEND_PORT=5173

# -----------------------------------------------------------------------------
# JWT Configuration (CHANGE IN PRODUCTION!)
# -----------------------------------------------------------------------------
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# -----------------------------------------------------------------------------
# Payment Configuration
# -----------------------------------------------------------------------------
PAYMENT_VPA=payflow@upi
PAYMENT_MERCHANT_NAME=PayFlow Merchant
PAYMENT_DEFAULT_CURRENCY=INR

# -----------------------------------------------------------------------------
# Simulator Configuration
# -----------------------------------------------------------------------------
SIMULATOR_WEBHOOK_SECRET=simulator_webhook_secret_change_me
SIMULATOR_WEBHOOK_URL=http://host.docker.internal:8083/api/v1/webhooks/simulator
SIMULATOR_SERVICE_URL=http://localhost:8086

# -----------------------------------------------------------------------------
# Idempotency Configuration
# -----------------------------------------------------------------------------
IDEMPOTENCY_REDIS_TTL_HOURS=24
IDEMPOTENCY_DB_TTL_HOURS=72

# -----------------------------------------------------------------------------
# Webhook & Payment Lifecycle Configuration
# -----------------------------------------------------------------------------
WEBHOOK_SERVICE_URL=http://localhost:8084
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_MS=5000
RAZORPAY_WEBHOOK_SECRET=dev_razorpay_secret
STRIPE_WEBHOOK_SECRET=dev_stripe_secret
PAYPAL_WEBHOOK_ID=dev_paypal_webhook_id
PAYMENT_EXPIRATION_ENABLED=true
PAYMENT_EXPIRATION_TIMEOUT=PT15M
PAYMENT_UPI_EXPIRATION_TIMEOUT=PT5M

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
LOG_LEVEL=INFO
