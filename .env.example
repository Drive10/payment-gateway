# ============================================================
# Payment Gateway - Environment Variables Template
# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env FILE WITH REAL SECRETS TO VERSION CONTROL
# ============================================================

# ---- PostgreSQL (Transactions) ----
POSTGRES_USER=payment
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=payment_gateway

# ---- MongoDB (Logs/Audit) ----
MONGO_USER=mongouser
MONGO_PASSWORD=<strong-mongo-password>
MONGO_DB=payment_logs

# ---- Redis (Caching) ----
REDIS_PASSWORD=<strong-redis-password>

# ---- Kafka (Event Streaming) ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ---- Elasticsearch (Search) ----
ELASTICSEARCH_URL=http://localhost:9200

# ---- Vault Configuration ----
# Production: Use Vault for secrets management
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=<vault-token>
VAULT_ENABLED=false

# ---- Service DB Users ----
AUTH_DB_USER=auth
ORDER_DB_USER=ord
PAYMENT_DB_USER=paymentuser
NOTIFICATION_DB_USER=notification
SIMULATOR_DB_USER=simulator
ANALYTICS_DB_USER=analytics

# ---- Service URLs (Internal Docker/K8s DNS) ----
AUTH_SERVICE_URL=http://auth-service:8081
ORDER_SERVICE_URL=http://order-service:8082
PAYMENT_SERVICE_URL=http://payment-service:8083
NOTIFICATION_SERVICE_URL=http://notification-service:8084
ANALYTICS_SERVICE_URL=http://analytics-service:8085
SIMULATOR_SERVICE_URL=http://simulator-service:8086

# ---- External Services ----
CHECKOUT_BASE_URL=http://localhost:3000
WEBHOOK_SERVICE_URL=http://notification-service:8084

# ---- Security ----
JWT_SECRET=<base64-encoded-secret-at-least-256-bits>
GATEWAY_INTERNAL_SECRET=<gateway-secret>

# ---- Simulator ----
SIMULATOR_SUCCESS_RATE=90
SIMULATOR_MODE=random

# ---- Frontend ----
VITE_API_GATEWAY_URL=http://localhost:8080
