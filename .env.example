POSTGRES_DB=platform
POSTGRES_USER=payment
POSTGRES_PASSWORD=paymentpass
JWT_SECRET_KEY=REPLACE_WITH_BASE64_ENCODED_SECRET
JWT_EXPIRATION_SECONDS=3600
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
PAYMENT_EVENTS_TOPIC=payment.events
PAYMENT_EVENTS_DLT_TOPIC=payment.events.dlt
DEFAULT_PROVIDER=RAZORPAY_SIMULATOR
CHECKOUT_BASE_URL=http://frontend
RAZORPAY_WEBHOOK_SECRET=dev_webhook_secret
PAYMENT_DB_URL=jdbc:postgresql://postgres:5432/paymentdb
AUTH_DB_URL=jdbc:postgresql://postgres:5432/authdb
LEDGER_DB_URL=jdbc:postgresql://postgres:5432/ledgerdb
NOTIFICATION_DB_URL=jdbc:postgresql://postgres:5432/notificationdb
RISK_DB_URL=jdbc:postgresql://postgres:5432/riskdb
SETTLEMENT_DB_URL=jdbc:postgresql://postgres:5432/settlementdb
SIMULATOR_DB_URL=jdbc:postgresql://postgres:5432/simulatordb
SIMULATOR_SERVICE_URL=http://simulator-service:8087
LEDGER_SERVICE_URL=http://ledger-service:8082
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans
REDIS_HOST=redis
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ZIPKIN_PORT=9411
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# ----- Hybrid Dev Overrides -----
# Uncomment any of these to route Docker API Gateway to your local IDE instance
# PAYMENT_SERVICE_URL=http://host.docker.internal:8084
# AUTH_SERVICE_URL=http://host.docker.internal:8081
# LEDGER_SERVICE_URL=http://host.docker.internal:8082
# NOTIFICATION_SERVICE_URL=http://host.docker.internal:8083
# RISK_SERVICE_URL=http://host.docker.internal:8085
# SETTLEMENT_SERVICE_URL=http://host.docker.internal:8086
# SIMULATOR_SERVICE_URL=http://host.docker.internal:8087
