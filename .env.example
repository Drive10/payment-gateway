# Shared runtime mode
SPRING_PROFILES_ACTIVE=local

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=payflow
DB_PASSWORD=payflow

# Service-specific logical DB names
AUTH_DB_NAME=auth_db
ORDER_DB_NAME=order_db
PAYMENT_DB_NAME=payment_db
NOTIFICATION_DB_NAME=notification_db
SIMULATOR_DB_NAME=simulator_db
ANALYTICS_DB_NAME=analytics_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=devpassword

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Mongo
MONGODB_URI=mongodb://localhost:27017/audit_db

# Security
JWT_SECRET=replace_with_base64_secret
GATEWAY_INTERNAL_SECRET=internal-gateway-secret

# Inter-service URLs
AUTH_SERVICE_URL=http://localhost:8081
ORDER_SERVICE_URL=http://localhost:8082
PAYMENT_SERVICE_URL=http://localhost:8083
NOTIFICATION_SERVICE_URL=http://localhost:8084
SIMULATOR_SERVICE_URL=http://localhost:8086
ANALYTICS_SERVICE_URL=http://localhost:8089
AUDIT_SERVICE_URL=http://localhost:8090

# Frontend
CHECKOUT_BASE_URL=http://localhost:5173

# Optional infra
VAULT_ENABLED=false
VAULT_ADDR=http://localhost:8200
CONSUL_ENABLED=false
CONSUL_HOST=consul
CONSUL_PORT=8500
