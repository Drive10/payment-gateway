# Database
DB_USERNAME=payflow
DB_PASSWORD=your_secure_db_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password

# JWT Authentication (minimum 32 characters)
JWT_SECRET=your_secure_jwt_secret_min_32_chars

# Internal Service Communication
GATEWAY_INTERNAL_SECRET=your_internal_gateway_secret
INTERNAL_SERVICE_SIGNING_SECRET=your_service_signing_secret

# Security
GATEWAY_TRUST_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Webhook Secrets
WEBHOOK_SIGNATURE_SECRET=your_webhook_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_SIGNING_SECRET=your_stripe_signing_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id