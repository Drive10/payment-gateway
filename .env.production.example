# ============================================================
# Payment Gateway - Environment Variables Template
# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env FILE WITH REAL SECRETS TO VERSION CONTROL
# ============================================================

# ============================================================
# REGISTRY CONFIGURATION
# ============================================================
# Options: ghcr.io (GitHub), docker.io (Docker Hub), localhost:5000 (local)
REGISTRY=ghcr.io
GITHUB_ORG=drive10
IMAGE_NAME=payment-gateway

# ============================================================
# SPRING PROFILE
# ============================================================
# Options: dev, docker, prod
SPRING_PROFILE=docker

# ============================================================
# VAULT CONFIGURATION
# ============================================================
# Production: Use Vault for secrets management
VAULT_ADDR=https://vault.production.internal:8200
VAULT_TOKEN=<vault-token>
VAULT_ENABLED=true

# ============================================================
# POSTGRESQL
# ============================================================
POSTGRES_USER=payment
POSTGRES_PASSWORD=<strong-password>

# ============================================================
# DATABASE USERS
# ============================================================
DB_USERNAME=payment
DB_PASSWORD=<database-password>

# ============================================================
# REDIS
# ============================================================
REDIS_PASSWORD=<strong-redis-password>

# ============================================================
# SERVICE URLs (Internal K8s/Docker DNS)
# ============================================================
AUTH_SERVICE_URL=http://auth-service:8081
ORDER_SERVICE_URL=http://order-service:8082
PAYMENT_SERVICE_URL=http://payment-service:8083
NOTIFICATION_SERVICE_URL=http://notification-service:8084
SIMULATOR_SERVICE_URL=http://simulator-service:8086
ANALYTICS_SERVICE_URL=http://analytics-service:8085

# ============================================================
# KAFKA
# ============================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ============================================================
# EXTERNAL SERVICES
# ============================================================
CHECKOUT_BASE_URL=https://checkout.yourdomain.com
WEBHOOK_SERVICE_URL=http://notification-service:8084

# ============================================================
# SIMULATOR
# ============================================================
SIMULATOR_SUCCESS_RATE=90
SIMULATOR_MODE=random
