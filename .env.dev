# Hybrid Local Dev - Environment Variables
# Services run on localhost, infra runs in Docker
# Usage: docker compose -f docker-compose.dev.yml --env-file .env.dev up -d

# ---- Security ----
JWT_SECRET_B64=dGhpcy1pcy1hLXZlcnktc2VjdXJlLWp3dC1zZWNyZXQta2V5LWZvci1maW50ZWNoLXBheW1lbnQta2V5LWJhc2U2NC1lbmNvZGVk
GATEWAY_INTERNAL_SECRET=dev-gateway-internal-secret

# ---- PostgreSQL ----
POSTGRES_USER=payment
POSTGRES_PASSWORD=pg-dev-password

# ---- Redis ----
REDIS_PASSWORD=redis-dev-pass

# ---- Service DB Credentials ----
AUTH_DB_USER=auth
AUTH_DB_PASSWORD=authpass
ORDER_DB_USER=ord
ORDER_DB_PASSWORD=orderpass
PAYMENT_DB_USER=payment
PAYMENT_DB_PASSWORD=paymentpass
NOTIFICATION_DB_USER=notification
NOTIFICATION_DB_PASSWORD=notificationpass
WEBHOOK_DB_USER=webhook
WEBHOOK_DB_PASSWORD=webhookpass
SIMULATOR_DB_USER=simulator
SIMULATOR_DB_PASSWORD=simulatorpass
SETTLEMENT_DB_USER=settlement
SETTLEMENT_DB_PASSWORD=settlementpass
RISK_DB_USER=risk
RISK_DB_PASSWORD=riskpass
ANALYTICS_DB_USER=analytics
ANALYTICS_DB_PASSWORD=analyticspass
MERCHANT_DB_USER=merchant
MERCHANT_DB_PASSWORD=merchantpass
DISPUTE_DB_USER=dispute
DISPUTE_DB_PASSWORD=disputepass

# ---- Local Service URLs (host.docker.internal = your machine) ----
AUTH_SERVICE_URL=http://host.docker.internal:8081
ORDER_SERVICE_URL=http://host.docker.internal:8082
PAYMENT_SERVICE_URL=http://host.docker.internal:8083
NOTIFICATION_SERVICE_URL=http://host.docker.internal:8084
WEBHOOK_SERVICE_URL=http://host.docker.internal:8085
SIMULATOR_SERVICE_URL=http://host.docker.internal:8086
SETTLEMENT_SERVICE_URL=http://host.docker.internal:8087
RISK_SERVICE_URL=http://host.docker.internal:8088
ANALYTICS_SERVICE_URL=http://host.docker.internal:8089
MERCHANT_SERVICE_URL=http://host.docker.internal:8090
DISPUTE_SERVICE_URL=http://host.docker.internal:8091
