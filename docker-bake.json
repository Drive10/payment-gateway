{
  "group": {
    "default": {
      "targets": ["auth-service", "order-service", "payment-service", "notification-service", "simulator-service", "analytics-service"]
    }
  },
  "target": {
    "auth-service": {
      "context": ".",
      "dockerfile": "Dockerfile.build",
      "args": {"SERVICE_PATH": "services/auth-service"},
      "tags": ["payment-gateway/auth-service:latest"]
    },
    "order-service": {
      "context": ".",
      "dockerfile": "Dockerfile.build",
      "args": {"SERVICE_PATH": "services/order-service"},
      "tags": ["payment-gateway/order-service:latest"]
    },
    "payment-service": {
      "context": ".",
      "dockerfile": "Dockerfile.build",
      "args": {"SERVICE_PATH": "services/payment-service"},
      "tags": ["payment-gateway/payment-service:latest"]
    },
    "notification-service": {
      "context": ".",
      "dockerfile": "Dockerfile.build",
      "args": {"SERVICE_PATH": "services/notification-service"},
      "tags": ["payment-gateway/notification-service:latest"]
    },
    "simulator-service": {
      "context": ".",
      "dockerfile": "Dockerfile.build",
      "args": {"SERVICE_PATH": "services/simulator-service"},
      "tags": ["payment-gateway/simulator-service:latest"]
    },
    "analytics-service": {
      "context": ".",
      "dockerfile": "Dockerfile.build",
      "args": {"SERVICE_PATH": "services/analytics-service"},
      "tags": ["payment-gateway/analytics-service:latest"]
    },
    "api-gateway": {
      "context": ".",
      "dockerfile": "Dockerfile.build",
      "args": {"SERVICE_PATH": "services/api-gateway"},
      "tags": ["payment-gateway/api-gateway:latest"]
    }
  }
}
