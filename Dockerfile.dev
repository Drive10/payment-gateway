# PayFlow Development Container
# Usage: docker build -f Dockerfile.dev -t payflow-dev . && docker run -it payflow-dev

FROM eclipse-temurin:21-jdk

ARG USER=developer
ARG UID=1000
ARG GID=1000

# Install development tools
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    vim \
    htop \
    net-tools \
    postgresql-client \
    redis-tools \
    unzip \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# Install Maven
RUN curl -fsSL https://archive.apache.org/dist/maven/maven-3/3.9.6/binaries/apache-maven-3.9.6-bin.tar.gz | tar -xz -C /opt \
    && ln -s /opt/apache-maven-3.9.6/bin/mvn /usr/bin/mvn

# Install Node.js
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Angular CLI globally
RUN npm install -g @angular/cli@17

# Create user
RUN groupadd -g $GID $USER || true \
    && useradd -m -u $UID -g $GID -s /bin/bash $USER || true

# Configure Maven settings
RUN mkdir - /home/$USER/.m2 \
    && chown -R $USER:$USER /home/$USER/.m2

COPY settings.xml /home/$USER/.m2/settings.xml
RUN chown -R $USER:$USER /home/$USER/.m2/settings.xml

# Working directory
WORKDIR /workspace
RUN chown -R $USER:$USER /workspace

# Switch to non-root user
USER $USER

# Environment variables
ENV MAVEN_OPTS="-Xmx1024m"
ENV NODE_OPTIONS="--max-old-space-size=2048"

# Default command
CMD ["/bin/bash"]