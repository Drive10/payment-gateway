{
  "name": "payflow-payment-page",
  "version": "1.0.0",
  "private": true,
  "description": "A polished fintech checkout experience built with React, Vite, Tailwind CSS, and Framer Motion.",
  "license": "MIT",
  "packageManager": "npm@10.9.0",
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "build:docker": "vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage --reporter=json --outputFile=coverage/vitest-report.json",
    "test:coverage:sonar": "vitest run --coverage --coverage.reporter=json --coverage.reporter=text --coverage.reporter=lcov --outputFile=coverage/vitest-report.json",
    "test:e2e": "playwright test",
    "test:e2e:fullstack": "playwright test tests/e2e/specs/fullstack-checkout.spec.ts --config=playwright.local.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report test-results/html"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "axios": "^1.14.0",
    "framer-motion": "^11.0.0",
    "jspdf": "^2.5.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.22.0",
    "sonner": "^2.0.7",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
