# PayFlow Environment Variables Example
# Copy this file to .env and update values as needed

# ===========================================
# CRITICAL - Generate strong secrets for production
# ===========================================
JWT_SECRET=<your-secure-jwt-secret-min-32-chars>
GATEWAY_INTERNAL_SECRET=<your-secure-internal-secret>
REDIS_PASSWORD=<your-secure-redis-password>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
STRIPE_SIGNING_SECRET=<your-stripe-signing-secret>
PAYPAL_WEBHOOK_ID=<your-paypal-webhook-id>
WEBHOOK_SIGNATURE_SECRET=<your-webhook-signature-secret>
INTERNAL_SERVICE_SIGNING_SECRET=<your-internal-service-signing-secret>

# CORS - comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Gateway Trust (set to true in production)
GATEWAY_TRUST_ENABLED=true

# Database Configuration (PostgreSQL)
DB_USERNAME=payflow
DB_PASSWORD=payflow

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<your-secure-redis-password>

# ===========================================
# Optional - Service URLs (for local dev without docker)
# ===========================================
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===========================================
# Optional - Service Ports
# ===========================================
# SERVER_PORT_AUTH_SERVICE=8081
# SERVER_PORT_API_GATEWAY=8080
# SERVER_PORT_ORDER_SERVICE=8082
# SERVER_PORT_PAYMENT_SERVICE=8083
# SERVER_PORT_NOTIFICATION_SERVICE=8084
# SERVER_PORT_SIMULATOR_SERVICE=8086
# SERVER_PORT_ANALYTICS_SERVICE=8089
# SERVER_PORT_AUDIT_SERVICE=8090