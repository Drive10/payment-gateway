# PayFlow Environment Variables Example
# Copy this file to .env and update values as needed

# ===========================================
# CRITICAL - Generate strong secrets for production
# ===========================================
JWT_SECRET=<your-secure-jwt-secret-min-32-chars>
GATEWAY_INTERNAL_SECRET=<your-secure-internal-secret>
REDIS_PASSWORD=<your-secure-redis-password>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>

# CORS - comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Gateway Trust (set to true in production)
GATEWAY_TRUST_ENABLED=true

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=payment_gateway
DB_USERNAME=payment
DB_PASSWORD=your_secure_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Consul Configuration
CONSUL_HOST=consul
CONSUL_PORT=8500
CONSUL_ENABLED=true

# Vault Configuration
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your_vault_token_here
VAULT_ENABLED=false
VAULT_SSL_ENABLED=false

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_minimum_32_chars

# Service Ports (optional - services will use defaults if not set)
SERVER_PORT_AUTH_SERVICE=8081
SERVER_PORT_API_GATEWAY=8080
SERVER_PORT_ORDER_SERVICE=8082
SERVER_PORT_PAYMENT_SERVICE=8083
SERVER_PORT_NOTIFICATION_SERVICE=8084
SERVER_PORT_SIMULATOR_SERVICE=8086
SERVER_PORT_GRAPHQL_GATEWAY=8087
SERVER_PORT_SEARCH_SERVICE=8088
SERVER_PORT_ANALYTICS_SERVICE=8089
SERVER_PORT_AUDIT_SERVICE=8089

# Application URLs
CHECKOUT_BASE_URL=http://localhost:3000
SIMULATOR_SERVICE_URL=http://localhost:8086
NOTIFICATION_SERVICE_URL=http://localhost:8084

# Feature Flags (optional)
FEATURE_FLAG_NEW_PAYMENT_PROCESSOR=true
FEATURE_FLAG_ADVANCED_ANALYTICS=false

# Logging Levels (optional)
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_DEV_PAYMENT=DEBUG
LOG_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=INFO